# Turso (libSQL) database - metadata only
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Cloudflare R2 (S3-compatible) - photo storage
# Create bucket + API token in Cloudflare dashboard
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=gray-family-photos
# Custom domain CNAME'd to the R2 bucket (set up in CF dashboard)
R2_PUBLIC_BASE_URL=https://photos.grayszone.com

# Nominatim (OpenStreetMap geocoding) - ToS requires identifying User-Agent
NOMINATIM_USER_AGENT=gray-family-photos/1.0 (mark@grayszone.com)

# 32-byte random hex (generate: openssl rand -hex 32)
SESSION_SECRET=replace_me_with_random_32_byte_hex

# Resend (email OTP delivery) - sign up at resend.com (free 3000/mo)
# OPTIONAL locally: if unset, codes are printed to the API server console
RESEND_API_KEY=re_xxx
# OPTIONAL: defaults to "Gray Family Photos <onboarding@resend.dev>"
# For production, configure a verified domain in Resend
RESEND_FROM_EMAIL=Gray Family Photos <noreply@grayszone.com>

# E2E tests target this base URL
E2E_BASE_URL=http://localhost:3000
