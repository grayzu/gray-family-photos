{
  "name": "gray-family-photos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch --env-file=.env.local scripts/dev-api.ts",
    "dev:full": "npm-run-all -p dev dev:api",
    "dev:vercel": "vercel dev",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx --env-file=.env.local node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --env-file=.env.local node_modules/drizzle-kit/bin.cjs studio",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@hono/node-server": "^2.0.3",
    "@libsql/client": "^0.17.3",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "drizzle-orm": "^0.45.2",
    "exifr": "^7.1.3",
    "heic2any": "^0.0.4",
    "hono": "^4.12.22",
    "pinia": "^3.0.4",
    "resend": "^6.12.3",
    "sharp": "^0.34.5",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vercel": "^54.4.1",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
